@page "/"
@using VetCare.Data
@using VetCare.Services
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject ApiService Api

<PageTitle>Dashboard — VetCare</PageTitle>

<div class="page-header">
    <div class="page-header-text">
        <h1>🐾 Bienvenido a VetCare</h1>
        <p>Panel de control — resumen del sistema veterinario</p>
    </div>
</div>

<div class="kpi-grid">
    <div class="kpi">
        <div class="kpi-icon">🐶</div>
        <div class="kpi-value">@totalMascotas</div>
        <div class="kpi-label">Mascotas registradas</div>
    </div>
    <div class="kpi">
        <div class="kpi-icon">📅</div>
        <div class="kpi-value">@citasHoy</div>
        <div class="kpi-label">Citas hoy</div>
    </div>
    <div class="kpi">
        <div class="kpi-icon">⏳</div>
        <div class="kpi-value">@citasPendientes</div>
        <div class="kpi-label">Citas pendientes</div>
    </div>
    <div class="kpi">
        <div class="kpi-icon">💉</div>
        <div class="kpi-value">@(totalServicios == null ? "…" : totalServicios.ToString())</div>
        <div class="kpi-label">Servicios en catálogo <small>(API)</small></div>
    </div>
</div>

<div class="card" style="margin-bottom:1.5rem;">
    <div class="card-title">⚡ Accesos rápidos</div>
    <div class="card-body">
        <div class="quick-actions">
            <a href="/mascotas" class="quick-action-card">
                <div class="quick-action-icon">🐶</div>
                Gestionar Mascotas
            </a>
            <a href="/catalogo" class="quick-action-card">
                <div class="quick-action-icon">📋</div>
                Ver Catálogo
            </a>
            <a href="/citas" class="quick-action-card">
                <div class="quick-action-icon">📅</div>
                Nueva Cita
            </a>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-title">🕐 Citas recientes</div>
    <div class="card-body">
        @if (citasRecientes == null)
        {
            <div class="loading">
                <div class="spinner"></div>
                <p>Cargando citas…</p>
            </div>
        }
        else if (!citasRecientes.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <p>No hay citas registradas aún.</p>
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Mascota</th>
                            <th>Dueño</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in citasRecientes)
                        {
                            <tr>
                                <td><strong>@c.Mascota?.Nombre</strong></td>
                                <td>@c.Mascota?.NombreDueno</td>
                                <td>@c.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge @BadgeClass(c.Estado)">@c.Estado</span></td>
                                <td><strong>$@c.Total.ToString("N2")</strong></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    int totalMascotas;
    int citasHoy;
    int citasPendientes;
    int? totalServicios;
    List<VetCare.Models.Cita>? citasRecientes;

    protected override async Task OnInitializedAsync()
    {
        totalMascotas = await Db.Mascotas.CountAsync();
        citasHoy = await Db.Citas.CountAsync(c => c.Fecha.Date == DateTime.Today);
        citasPendientes = await Db.Citas.CountAsync(c => c.Estado == "Programada");
        citasRecientes = await Db.Citas
                                  .Include(c => c.Mascota)
                                  .OrderByDescending(c => c.Fecha)
                                  .Take(5)
                                  .ToListAsync();

        var servicios = await Api.GetServiciosAsync();
        totalServicios = servicios?.Count;
    }

    string BadgeClass(string estado) => estado switch
    {
        "Atendida" => "badge-green",
        "Cancelada" => "badge-red",
        _ => "badge-yellow"
    };
}