@page "/catalogo"
@using VetCare.Services
@using VetCare.Models
@inject ApiService Api

<PageTitle>Catálogo de Servicios — VetCare</PageTitle>

<div class="page-header">
    <h1>📋 Catálogo de Servicios</h1>
    <p>Servicios disponibles — fuente: API del profesor</p>
</div>

@if (errorApi)
{
    <div class="alert alert-error">⚠️ No se pudo conectar a la API. Verifica tu conexión e intenta de nuevo.</div>
}

<div class="filter-bar">
    <label>Filtrar por especialidad:</label>
    @if (especialidades == null)
    {
        <span style="color:var(--text-muted)">Cargando filtros…</span>
    }
    else
    {
        <select class="form-control" style="width:auto" @onchange="FiltrarPorEspecialidad">
            <option value="0">— Todas las especialidades —</option>
            @foreach (var esp in especialidades)
            {
                <option value="@esp.Id">@esp.Nombre</option>
            }
        </select>
    }
    @if (especialidadSeleccionada > 0)
    {
        <button class="btn btn-secondary btn-sm" @onclick="LimpiarFiltro">✕ Limpiar filtro</button>
    }
</div>

@if (servicios == null)
{
    <div class="loading"><span>⟳</span> Cargando catálogo…</div>
}
else if (!servicios.Any())
{
    <p style="color:var(--text-muted)">No se encontraron servicios para esta especialidad.</p>
}
else
{
    <p style="color:var(--text-muted); margin-bottom:1rem;">
        Mostrando <strong>@servicios.Count</strong> servicio(s)
    </p>
    <div class="catalog-grid">
        @foreach (var s in servicios)
        {
            <div class="catalog-card">
                <div class="svc-name">@s.Nombre</div>
                <div class="svc-desc">@s.Descripcion</div>
                <div class="svc-price">$@s.Precio.ToString("N2")</div>
                <div class="svc-meta">
                    ⏱ @s.Duracion min
                    @if (s.RequiereCita)
                    {
                        <span class="badge badge-blue" style="margin-left:.5rem">Requiere cita</span>
                    }
                    else
                    {
                        <span class="badge badge-green" style="margin-left:.5rem">Sin cita previa</span>
                    }
                </div>
                <div class="svc-meta">🏥 @s.Especialidad</div>
            </div>
        }
    </div>
}

@code {
    List<ServicioApi>? servicios;
    List<EspecialidadApi>? especialidades;
    int especialidadSeleccionada = 0;
    bool errorApi = false;

    protected override async Task OnInitializedAsync()
    {
        servicios = await Api.GetServiciosAsync();
        especialidades = await Api.GetEspecialidadesAsync();
        if (servicios == null) errorApi = true;
    }

    async Task FiltrarPorEspecialidad(ChangeEventArgs e)
    {
        errorApi = false;
        int id = int.TryParse(e.Value?.ToString(), out int v) ? v : 0;
        especialidadSeleccionada = id;

        if (id == 0)
            servicios = await Api.GetServiciosAsync();
        else
            servicios = await Api.GetServiciosPorEspecialidadAsync(id);

        if (servicios == null) errorApi = true;
    }

    async Task LimpiarFiltro()
    {
        especialidadSeleccionada = 0;
        servicios = await Api.GetServiciosAsync();
        if (servicios == null) errorApi = true;
    }
}